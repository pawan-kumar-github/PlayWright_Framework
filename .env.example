# ─────────────────────────────────────────────
#  Environment Configuration Template
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Environment name: dev | staging | uat | prod
ENV=staging

# Application base URL
BASE_URL=https://your-application-url.com

# Test credentials
TEST_USERNAME=automation_user@example.com
TEST_PASSWORD=AutoTest@1234

# Admin credentials
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=Admin@1234

# API base URL (for setup/teardown API calls)
API_BASE_URL=https://api.your-application.com

# Allure server (optional, for CI)
ALLURE_SERVER_URL=

# CI flag
CI=false
